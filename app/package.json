{
  "name": "weaveself-app",
  "version": "0.1.0",
  "private": true,
  "description": "WeaveSelf Track C - CopilotKit React app, runtime endpoint, Redis client, and shared contracts (Node/TS).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "tsc",
