# =============================================================================
# OpenMirror — environment template (.env.example)
# =============================================================================
# Copy to `.env` and fill in what you need. Real `.env` is git-ignored.
#
#   cp .env.example .env
#
# Production UI env lives in ui/.env.example (Next.js proxies).
# WeaveSelf research code (ml/weaveself/) has its own vars below for reference.
# =============================================================================


# -----------------------------------------------------------------------------
# OpenMirror — shared (Tracks A, B, D, memory)
# -----------------------------------------------------------------------------
# Frozen instruct base model (Track A serves; never finetuned).
BASE_MODEL_ID=Qwen/Qwen2.5-7B-Instruct

# Track A — NTK train / compose / act
TRACK_A_URL=http://127.0.0.1:8000
CONTROLLER_DIR=./controllers

# Track B — control plane (Redis required)
CP_URL=http://127.0.0.1:8100
# Redis Cloud: if rediss:// fails with WRONG_VERSION_NUMBER, use redis:// for that port
REDIS_URL=redis://127.0.0.1:6379/0
CP_MAX_NEW_TOKENS=16

# Track D — agents / brain (optional vLLM for live reasoning)
AG_URL=http://127.0.0.1:8200
OPENMIRROR_BRAIN_BASE_URL=http://127.0.0.1:8001/v1
OPENMIRROR_BRAIN_MODEL=Qwen/Qwen2.5-14B-Instruct

# Memory — chat log curation (optional; heuristic works without OpenAI)
OPENAI_API_KEY=
CURATION_MODEL=gpt-4o-mini

# Weave tracing (Weights & Biases — sponsor)
WEAVE_PROJECT=openmirror
WANDB_API_KEY=
WANDB_PROJECT=openmirror

# Hybrid capability approval (Track B)
# Default for the UI toggle when Redis has no stored value yet.
OPENMIRROR_AUTO_APPROVE=true
# Per-skill overrides (comma-separated skill names):
# OPENMIRROR_REQUIRE_APPROVAL=web_search
# OPENMIRROR_AUTOAPPROVE=calendar
OPENMIRROR_APPROVAL_TIMEOUT_S=120


# -----------------------------------------------------------------------------
# WeaveSelf reference (ml/weaveself/ — merged from main, not production path)
# -----------------------------------------------------------------------------
WEAVESELF_BACKEND=stub
INFERENCE_API_URL=http://127.0.0.1:8000
ADAPTERS_DIR=./data/adapters
TORCH_DEVICE=cpu
HF_HOME=./.hf-cache
HUGGING_FACE_HUB_TOKEN=
DATA_DIR=./data/source
WANDB_API_KEY=
WANDB_PROJECT=weaveself
