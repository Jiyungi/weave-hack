# =============================================================================
# WeaveSelf — environment template (.env.example)
# =============================================================================
# ONE file, divided by engineer/track. Copy to `.env` and fill in the section(s)
# you own. Sections below map to the three-engineer split in tasks.md.
#
#   cp .env.example .env
#
# Real `.env` files are git-ignored; only this `.example` is committed.
# Never commit real API keys. Browser-exposed vars (Track C) MUST be prefixed
# (VITE_ / NEXT_PUBLIC_) — never prefix a secret.
# =============================================================================


# -----------------------------------------------------------------------------
# SHARED — everyone needs these
# -----------------------------------------------------------------------------
# Frozen instruct Base_Model (Track A serves it; B & C reference it).
BASE_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct
# BASE_MODEL_ID=Qwen/Qwen2.5-7B-Instruct   # use for the real demo if GPU allows

# Inference_API location (Track A hosts; Track B & C are clients).
INFERENCE_API_URL=http://127.0.0.1:8000

# Redis (Track C owns; Track A & B are clients).
REDIS_URL=redis://127.0.0.1:6379

# AG-UI bridge (Node/TS CopilotKit runtime <-> Python LangGraph agent).
AG_UI_URL=http://127.0.0.1:8123

# Shared on-disk adapter storage (adapter_<id>.safetensors / .json pairs).
ADAPTERS_DIR=./data/adapters

LOG_LEVEL=info


# -----------------------------------------------------------------------------
# ENGINEER A — Track A: Model & Serving  (Python `ml/`)
# Owns: NKT-Mirror training, custom serving, FastAPI Inference_API, train_adapter
# -----------------------------------------------------------------------------
# Serving backend: stub = dependency-free fake (tests/CI, no GPU);
#                  hf   = real HuggingFace model (needs `pip install -e .[serving]`).
WEAVESELF_BACKEND=stub
# Real-model settings (only used when WEAVESELF_BACKEND=hf):
TORCH_DEVICE=cpu                       # cpu | cuda | cuda:0 | mps
MODEL_DTYPE=bfloat16                   # float32 | float16 | bfloat16
HF_HOME=./.hf-cache                    # keeps multi-GB downloads off system drive
HUGGING_FACE_HUB_TOKEN=hf_your_token_here   # only for gated/private models
# Inference_API service bind:
INFERENCE_API_HOST=127.0.0.1
INFERENCE_API_PORT=8000
DEFAULT_MAX_NEW_TOKENS=256
# train_adapter: hard ceiling on serialized adapter size (~5K gate params).
ADAPTER_MAX_BYTES=200000


# -----------------------------------------------------------------------------
# ENGINEER B — Track B: Data, Orchestration & Eval  (Python `ml/`)
# Owns: data pipeline, GPT curation node, LangGraph nightly batch, Weave eval
# -----------------------------------------------------------------------------
# GPT curation node — Track B is the ONLY component allowed to call GPT.
OPENAI_API_KEY=sk-your_openai_key_here
CURATION_MODEL=gpt-4o-mini
CURATION_BACKEND=openai                # openai | local
LOCAL_CURATION_MODEL=Qwen/Qwen2.5-1.5B-Instruct   # when CURATION_BACKEND=local
# Weave / Weights & Biases logging.
WANDB_API_KEY=your_wandb_key_here
WANDB_ENTITY=your_wandb_entity
WANDB_PROJECT=weaveself
WEAVE_PROJECT=weaveself
# Data pipeline.
DATA_DIR=./data/source
SPLITS_DIR=./data/splits
MIN_ROWS=20                            # min source rows for a Unit to be included
HELDOUT_FRACTION=0.2                   # train/heldout split (no per-Unit overlap)
# Nightly batch (training is batch/overnight ONLY — never on a live chat request).
BATCH_SCHEDULE=0 3 * * *               # cron; demo is time-compressed
DAY_INDEX=0                            # keys pre-baked demo adapters


# -----------------------------------------------------------------------------
# ENGINEER C — Track C: Frontend, Redis & Integration  (Node/TS `app/`)
# Owns: CopilotKit React app, AG-UI<->LangGraph wiring, Redis layer, demo glue
# -----------------------------------------------------------------------------
COPILOTKIT_RUNTIME_URL=http://127.0.0.1:3000/api/copilotkit
LANGGRAPH_AGENT_URL=http://127.0.0.1:8123   # agent the AG-UI bridge connects to (SSE)
FRONTEND_PORT=3000
# OpenAI key for the CopilotKit runtime (server-side only — do NOT expose).
# (Same key as Track B's OPENAI_API_KEY if you share one account.)
# Vector routing: route(query_or_user) -> top-1 adapter_id over unit-label embeddings.
EMBEDDING_PROVIDER=openai              # openai | local
EMBEDDING_MODEL=text-embedding-3-small
# Eval artifact the dashboard renders (confusion matrix, examples, size chart).
EVAL_RESULTS_PATH=./data/eval_results.json
# Browser-exposed (safe, non-secret) — prefix required:
VITE_INFERENCE_API_URL=http://127.0.0.1:8000
